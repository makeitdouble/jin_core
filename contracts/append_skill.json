      "<INTERNAL_ACTION_APPEND_SKILL:",
      "<INTERNAL_ACTION_APPEND_SKILLS",
      "<INTERNAL_ACTION_APPEND_SKILLS:",
      "INTERNAL_ACTION_APPEND_SKILL:",
      "INTERNAL_ACTION_APPEND_SKILLS:",
      "<|tool_call>call:INTERNAL_ACTION_APPEND_SKILL:",
      "<tool_call>call:INTERNAL_ACTION_APPEND_SKILL:",
      "<|tool_call>call:INTERNAL_ACTION_APPEND_SKILLS:",
      "<tool_call>call:INTERNAL_ACTION_APPEND_SKILLS:",
      "<|tool_call>call:APPEND_SKILL:",
      "<tool_call>call:APPEND_SKILL:",
      "<|tool_call>call:APPEND_SKILLS:",
