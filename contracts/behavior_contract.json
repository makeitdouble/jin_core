{
  "version": 1,
  "action_guards": {
    "save_session": {
      "description": "Allows the model to request saving the current session when the user clearly ends, wraps up, or asks to save the session.",
      "runtime_action": "SAVE_SESSION",
      "private_marker": "<INTERNAL_ACTION_SAVE_SESSION>",
      "triggers": [
        "закончим",
        "на сегодня все",
        "на сегодня всё",
        "я ухожу",
        "я спать",
        "пойду спать",
        "до завтра",
        "спокойной ночи",
        "заканчиваем",
        "сохрани сессию",
        "сохрани текущий разговор",
        "запомни где остановились",
        "подведи итог и закрой",
        "save session",
        "save this session",
        "remember where we stopped",
        "wrap up and save",
        "продолжим завтра",
        "сохрани и закрой",
        "сохрани на сегодня",
        "давай на сегодня всё",
        "на сегодня хватит"
      ],
      "blockers": [
        "покажи тег",
        "напиши тег",
        "полный тег",
        "точный тег",
        "пример тега",
        "как выглядит тег",
        "процитируй тег",
        "show tag",
        "write tag",
        "exact tag",
        "full tag",
        "tag example",
        "quote tag",
        "сохрани это",
        "сохранить это",
        "сохрани как",
        "сохрани это как",
        "запомни это",
        "запомни как",
        "save this",
        "save it",
        "remember this",
        "remember it"
      ],
      "effects": {
        "save_session": true,
        "suppress_followup": true,
        "suppress_offer": true,
        "final_reply_mode": "short_closure"
      }
    },
    "remember_event": {
      "description": "Classifies a REMEMBER_EVENT request as user-initiated when the user explicitly marks the current moment or detail as worth saving.",
      "runtime_action": "REMEMBER_EVENT",
      "private_marker": "<INTERNAL_ACTION_REMEMBER_EVENT>",
      "triggers": [
        "хочу это запомнить",
        "хочу запомнить",
        "сохрани это",
        "сохранить это",
        "это надо сохранить",
        "это надо запомнить",
        "запомни это",
        "важный момент",
        "надо сохранить"
      ],
      "blockers": [
        "покажи тег",
        "напиши тег",
        "полный тег",
        "точный тег",
        "пример тега",
        "как выглядит тег",
        "процитируй тег",
        "show tag",
        "write tag",
        "exact tag",
        "full tag",
        "tag example",
        "quote tag"
      ],
      "effects": {
        "save_event": true
      }
    }
  }
}
